# =====================================================================
# LLM provider — pick ONE of "anthropic" or "openrouter"
# =====================================================================
LLM_PROVIDER=anthropic
# LLM_PROVIDER=openrouter

# ---------- Anthropic official ----------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
# Optional: override base_url (proxy / Bedrock / Vertex)
# ANTHROPIC_BASE_URL=

# ---------- OpenRouter (OpenAI-compatible) ----------
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Examples:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   google/gemini-2.5-pro
#   deepseek/deepseek-r1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REFERER=https://github.com/local/rl-agent-tutor
# OPENROUTER_TITLE=RL Agent Tutor

# =====================================================================
# Latency tuning
# =====================================================================
# Defaults favor interactive use. Increase these if your provider is slow.
LLM_REQUEST_TIMEOUT=90
LLM_CONNECT_TIMEOUT=15
LLM_MAX_RETRIES=1
LLM_BACKOFF_BASE=1.5
# Optional global token budget multiplier. Example: 0.7 for faster, shorter output.
LLM_MAX_TOKEN_SCALE=1.0

# Optional task-level model overrides. Useful with OpenRouter:
# keep COURSEWARE/PLANNER on a stronger model, use faster/cheaper models for
# Tutor, practice, tests, rerank and resource planning.
# PLANNER_MODEL=
# LIBRARIAN_MODEL=
# COURSEWARE_MODEL=
# PRACTICE_MODEL=
# TUTOR_MODEL=
# EXAMINER_MODEL=
# RERANK_MODEL=
# ARCHIVIST_MODEL=
# REVIEWER_MODEL=

# =====================================================================
# Workspace
# =====================================================================
WORKSPACE_DIR=./workspace
